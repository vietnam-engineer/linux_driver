# EditorConfig: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C, C++
[*.{c,h}]
indent_style = tab
indent_size = 4

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 4
